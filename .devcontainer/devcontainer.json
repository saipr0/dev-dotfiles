{
  "name": "devbox",
  "image": "ghcr.io/saipr0/devbox:debian",
  "remoteUser": "saipr",
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localEnv:HOME}/workspace,target=/workspace,type=bind",
  "mounts": [
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ]
}
